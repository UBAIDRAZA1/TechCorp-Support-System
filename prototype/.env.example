# Environment Variables

# Grok API (xAI) - Get your API key from https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/crm_digital_fte

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_INCOMING=incoming_messages
KAFKA_TOPIC_OUTGOING=outgoing_messages

# Email (Gmail)
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret
GMAIL_REDIRECT_URI=http://localhost:8000/auth/callback

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Logging
LOG_LEVEL=INFO
